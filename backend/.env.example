# Server configuration
PORT=5000
NODE_ENV=development

# Database configuration
# Set this to your local PostgreSQL connection string, or your Render managed Postgres URL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/language_learning_platform?schema=public"

# Auth configuration
JWT_SECRET="super-secret-key-change-in-production"

# OpenAI Chatbot integration
OPENAI_API_KEY="your-openai-api-key-here"

# Frontend Client URL (for CORS validation)
CLIENT_URL="http://localhost:5173"

# S3-compatible file storage credentials (optional - falls back to local disk storage if undefined)
# S3_BUCKET="your-bucket-name"
# S3_REGION="us-east-1"
# S3_ACCESS_KEY_ID="your-access-key-id"
# S3_SECRET_ACCESS_KEY="your-secret-access-key"
# S3_ENDPOINT="https://s3.amazonaws.com"
